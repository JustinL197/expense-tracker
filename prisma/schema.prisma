// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model expenses {
  id         Int        @id @default(autoincrement()) 
  title      String  
  category   String
  timestamp  DateTime 
  amount     Decimal
}